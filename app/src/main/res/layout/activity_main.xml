<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base">

    <!-- Top Bar (Sticky) -->
    <RelativeLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AudSel"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:background="@color/bg_elevated"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="v2.0"
            android:textColor="@color/blue"
            android:textSize="11sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- Main Content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/main_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/top_bar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="40dp">

            <!-- Hero/Status Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/bg_elevated"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <androidx.cardview.widget.CardView
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            app:cardBackgroundColor="@color/bg_surface"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp">
                            <ImageView
                                android:id="@+id/hero_icon"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_gravity="center"
                                android:src="@drawable/hero_logo" />
                        </androidx.cardview.widget.CardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="AudSel Pro"
                                android:textColor="@color/text_primary"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/sys_info"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="System Initializing..."
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="20dp"
                        android:background="@color/border" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:id="@+id/status_dot"
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/card_bg" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:text="CURRENT MODE"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:id="@+id/active_mode_name"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="end"
                            android:text="NORMAL"
                            android:textColor="@color/blue"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Device Info Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:alpha="0.5"
                    android:src="@android:drawable/ic_lock_silent_mode_off"
                    app:tint="@color/text_secondary" />

                <TextView
                    android:id="@+id/device_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Detecting Device..."
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Parameters Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:letterSpacing="0.1"
                android:text="PARAMETERS"
                android:textColor="@color/text_tertiary"
                android:textSize="10sp"
                android:textStyle="bold" />

            <!-- Stats Grid -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:columnCount="2">

                <!-- Sample Rate -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardBackgroundColor="@color/bg_elevated"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="SAMPLE RATE"
                                android:textColor="@color/text_tertiary"
                                android:textSize="9sp"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/live_indicator_khz"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="LIVE"
                                android:textColor="@color/green"
                                android:textSize="7sp"
                                android:textStyle="bold"
                                android:background="@drawable/card_bg"
                                android:backgroundTint="#2210B981"
                                android:paddingHorizontal="4dp"
                                android:paddingVertical="1dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/khz_layout"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:gravity="bottom"
                            android:orientation="horizontal">
                            <TextView
                                android:id="@+id/khz_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="48"
                                android:textColor="@color/text_primary"
                                android:textSize="22sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="2dp"
                                android:layout_marginBottom="3dp"
                                android:text="kHz"
                                android:textColor="@color/text_tertiary"
                                android:textSize="10sp" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Buffer -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardBackgroundColor="@color/bg_elevated"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="BUFFER"
                                android:textColor="@color/text_tertiary"
                                android:textSize="9sp"
                                android:textStyle="bold" />
                            <TextView
                                android:id="@+id/live_indicator_buffer"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="REALTIME"
                                android:textColor="@color/blue"
                                android:textSize="7sp"
                                android:textStyle="bold"
                                android:background="@drawable/card_bg"
                                android:backgroundTint="#223B82F6"
                                android:paddingHorizontal="4dp"
                                android:paddingVertical="1dp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/buffer_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="24ms"
                            android:textColor="@color/text_primary"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Resampler -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardBackgroundColor="@color/bg_elevated"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="RESAMPLER"
                            android:textColor="@color/text_tertiary"
                            android:textSize="9sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/resampler_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="4"
                            android:textColor="@color/text_primary"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Hi-Fi DAC -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    app:cardBackgroundColor="@color/bg_elevated"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="HI-FI DAC"
                            android:textColor="@color/text_tertiary"
                            android:textSize="9sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/hifi_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="OFF"
                            android:textColor="@color/text_primary"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </GridLayout>

            <!-- Profiles Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:letterSpacing="0.1"
                android:text="AUDIO PROFILES"
                android:textColor="@color/text_tertiary"
                android:textSize="10sp"
                android:textStyle="bold" />

            <!-- Profile List -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Normal -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/mode_normal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardBackgroundColor="@color/bg_elevated"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                        <androidx.cardview.widget.CardView
                            android:id="@+id/icon_bg_normal"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            app:cardBackgroundColor="@color/border"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp">
                            <ImageView 
                                android:id="@+id/icon_normal"
                                android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_normal" android:layout_gravity="center" app:tint="@color/text_primary" />
                        </androidx.cardview.widget.CardView>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Normal" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="14sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Balanced — Daily Listening" android:textColor="@color/text_tertiary" android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Bass Booster -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/mode_bass"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardBackgroundColor="@color/bg_elevated"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                        <androidx.cardview.widget.CardView
                            android:id="@+id/icon_bg_bass"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            app:cardBackgroundColor="@color/border"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp">
                            <ImageView 
                                android:id="@+id/icon_bass"
                                android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_bass" android:layout_gravity="center" app:tint="@color/text_primary" />
                        </androidx.cardview.widget.CardView>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bass Booster" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="14sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Deep low-end, punchy bass" android:textColor="@color/text_tertiary" android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Gaming -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/mode_gaming"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardBackgroundColor="@color/bg_elevated"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                        <androidx.cardview.widget.CardView
                            android:id="@+id/icon_bg_gaming"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            app:cardBackgroundColor="@color/border"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp">
                            <ImageView 
                                android:id="@+id/icon_gaming"
                                android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_gaming" android:layout_gravity="center" app:tint="@color/text_primary" />
                        </androidx.cardview.widget.CardView>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Gaming" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="14sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Low latency, sharp details" android:textColor="@color/text_tertiary" android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Hi-Fi -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/mode_hifi"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardBackgroundColor="@color/bg_elevated"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                        <androidx.cardview.widget.CardView
                            android:id="@+id/icon_bg_hifi"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            app:cardBackgroundColor="@color/border"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp">
                            <ImageView 
                                android:id="@+id/icon_hifi"
                                android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_hifi" android:layout_gravity="center" app:tint="@color/text_primary" />
                        </androidx.cardview.widget.CardView>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hi-Fi" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="14sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Highest quality audio fidelity" android:textColor="@color/text_tertiary" android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Cinema -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/mode_cinema"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardBackgroundColor="@color/bg_elevated"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                        <androidx.cardview.widget.CardView
                            android:id="@+id/icon_bg_cinema"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            app:cardBackgroundColor="@color/border"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp">
                            <ImageView 
                                android:id="@+id/icon_cinema"
                                android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_cinema" android:layout_gravity="center" app:tint="@color/text_primary" />
                        </androidx.cardview.widget.CardView>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="16dp" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cinema" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="14sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Immersive surround sound" android:textColor="@color/text_tertiary" android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:text="Optimized for Redmi 10 | Selene\nKYY Audio Pro v3.0"
                android:textColor="@color/text_tertiary"
                android:textSize="10sp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Module Missing Layout -->
    <LinearLayout
        android:id="@+id/module_missing_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg_base"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="40dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Requirement Missing"
            android:textColor="@color/rose"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/module_missing_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="Mohon instal module KYY Audio Pro terlebih dahulu lewat Magisk/KSU untuk menggunakan APK ini."
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btn_download_module"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:backgroundTint="@color/blue"
            android:text="Download Module"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:cornerRadius="12dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
